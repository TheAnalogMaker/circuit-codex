---
import Base from '../../layouts/Base.astro';
import { topologyCrossCuts, displayId } from '../../lib/corpus.js';

const dims = topologyCrossCuts();
const canonical = new URL('topology/', Astro.site).href;
const description = 'Browse every classic tube-amp circuit in the archive by design choice — '
  + 'phase inverter, output-stage bias, rectifier, and tone stack. Find every '
  + 'long-tailed-pair, fixed-bias, or tube-rectifier amp gathered in one place.';
const jsonld = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Amp topology — browse by circuit design',
  description,
  url: canonical,
  inLanguage: 'en',
  publisher: { '@type': 'Organization', name: 'Circuit Codex' },
};
---
<Base title="Amp topology — browse by circuit design · Circuit Codex"
      description={description} jsonld={jsonld}>
<div class="wrap">
  <header class="hero">
    <div class="eyebrow">Topology</div>
    <h1>Browse the archive by circuit design.</h1>
    <p class="lede">The same handful of design decisions recur across four decades of
      amplifiers — how the signal is split for a push-pull output stage, how the
      output tubes are biased, what rectifies the high-voltage rail, and how the tone
      controls are wired. Each choice below gathers every amp in the corpus that made
      it, side by side with the neighbouring circuits that chose differently.</p>
  </header>

  {dims.map((dim) => (
    <section>
      <h2>{dim.label}</h2>
      <p class="sub">{dim.blurb}</p>
      <div class="grid">
        {dim.pages.map((p) => (
          <a class="card" href={`/topology/${p.slug}/`}>
            <div class="cid">{p.label}</div>
            <div class="chips">
              <span class="chip">{p.amps.length} amp{p.amps.length === 1 ? '' : 's'}</span>
            </div>
            <div class="cdesc">{p.amps.map((a) => displayId(a.id)).join(' · ')}</div>
          </a>
        ))}
      </div>
    </section>
  ))}
</div>
</Base>

<style>
  .hero{padding:64px 0 12px}
  .eyebrow{font-family:var(--disp);text-transform:uppercase;letter-spacing:.26em;font-size:12.5px;color:var(--amber)}
  h1{font-size:clamp(30px,5vw,48px);line-height:1.1;margin:14px 0 16px}
  .lede{max-width:66ch;color:var(--muted);font-size:16.5px;margin:0}
  section{margin-top:40px}
  h2{font-size:19px;letter-spacing:.14em;margin:24px 0 4px}
  .sub{color:var(--muted);font-size:14.5px;margin:0 0 20px;max-width:74ch}
  .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:14px}
  .card{background:var(--panel);border:1px solid var(--line);border-radius:8px;padding:16px 18px 14px;display:flex;flex-direction:column;gap:8px;color:inherit}
  .card:hover{border-color:var(--amber-dim);text-decoration:none}
  .card .cid{font-family:var(--disp);font-size:17px;line-height:1.2;letter-spacing:.02em;text-transform:uppercase}
  .card .cdesc{color:var(--faint);font-family:var(--mono);font-size:11.5px;line-height:1.5;margin-top:auto}
  .chips{display:flex;gap:8px;flex-wrap:wrap}
</style>
