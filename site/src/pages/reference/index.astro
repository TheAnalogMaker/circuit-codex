---
import Base from '../../layouts/Base.astro';
import { loadSources, loadTubes, loadStudies, pdBasis, GITHUB } from '../../lib/corpus.js';

const sources = loadSources();
const tubes = loadTubes();
const studies = loadStudies();
const manuals = sources.filter((s) => s.category === 'tube-manual');
const era = sources.filter((s) => s.category === 'era-component');

// pd_basis token → chip class (colour). Anything unknown falls back to neutral.
const pdClass = {
  'pd-outright': 'ok',
  'non-renewal': 'ok',
  'pd-mark': 'v',
  'renewal-dependent': '',
  'in-copyright': 'warn',
};

const guides = [
  { href: '/reference/guides/resistor-color-code/', title: 'Resistor color code calculator',
    desc: 'Read the bands or type a value — four-band and five-band, with tolerance.' },
  { href: '/reference/guides/capacitor-codes/', title: 'Capacitor code chart & decoder',
    desc: 'Decode three-digit codes and tolerance letters; convert µF, nF, and pF.' },
  { href: '/reference/guides/tube-pinouts/', title: 'Tube pinout diagrams',
    desc: 'Interactive bottom-view basing for all nine tubes — noval, 7-pin, and octal.' },
  { href: '/reference/guides/calculators/', title: 'Amp builder calculators',
    desc: "Ohm's law, cathode bias, coupling-cap corners, and transformer ratios." },
  { href: '/reference/guides/tube-substitution/', title: 'Tube substitution & the gain ladder',
    desc: 'Interactive 9A dual-triode gain ladder, plus power-tube and rectifier interchange.' },
  { href: '/reference/guides/transformers/', title: 'Transformer reference',
    desc: 'Power-transformer lead colours, every transformer and choke in the corpus, and the impedance-ratio sum.' },
  { href: '/reference/glossary/', title: 'Glossary',
    desc: 'Plain-language definitions for the amp-building and tube-electronics terms used across the corpus, with a stable anchor per term.' },
];
---
<Base title="Reference library — Circuit Codex"
      description="The datasheets, tube manuals, and era-component references behind the corpus — linked to established archives, with a documented public-domain basis noted for each. Plus original metrology studies.">
<div class="wrap">
  <header class="hero">
    <div class="eyebrow">Reference library</div>
    <h1>The sources behind the corpus.</h1>
    <p class="lede">Every voltage, part value, and tube model in this archive traces
      back to primary literature — datasheets, tube manuals, and the engineering
      references of the era. This is that shelf, kept in the open.</p>
    <div class="posture">
      <strong>Our posture.</strong> We link to established archives; we rehost only
      material with a documented public-domain basis. Extracted data are presented as
      facts with attribution, never as reproductions of the source documents. Every
      entry below points at the holding archive — nothing here is rehosted.
    </div>
  </header>

  {studies.length > 0 && (
    <section>
      <h2>Studies</h2>
      <p class="sub">Original metrology write-ups from building the corpus — the
        questions the published data raised, and how we resolved them.</p>
      <div class="grid">
        {studies.map((s) => (
          <a class="card study" href={`/reference/studies/${s.slug}/`}>
            <div class="ct">Study</div>
            <div class="cid">{s.title}</div>
            {s.subtitle && <div class="cdesc">{s.subtitle}</div>}
          </a>
        ))}
      </div>
    </section>
  )}

  <section>
    <h2>Practical guides</h2>
    <p class="sub">Interactive bench tools and quick references built from the same
      corpus — decode a part, run the small sums that come up while working on these
      circuits, or look up a term.</p>
    <div class="grid">
      {guides.map((g) => (
        <a class="card guide" href={g.href}>
          <div class="ct">Guide</div>
          <div class="cid">{g.title}</div>
          <div class="cdesc">{g.desc}</div>
        </a>
      ))}
    </div>
  </section>

  <section>
    <h2>Datasheets by tube</h2>
    <p class="sub">The nine tubes this corpus models, each with the manufacturer
      datasheets its model is fitted and cross-checked against.
      <a href={`${GITHUB}/blob/main/models/METHODOLOGY.md`}>How the models are derived →</a></p>
    <div class="grid">
      {tubes.map((t) => (
        <a class="card" href={`/reference/tubes/${t.tube}/`}>
          <div class="cid">{t.name}</div>
          {t.also_known_as && t.also_known_as.length > 0 && (
            <div class="cdesc aka">= {t.also_known_as.join(' · ')}</div>
          )}
          <div class="chips">
            <span class="chip">{t.datasheets.length} datasheet{t.datasheets.length === 1 ? '' : 's'}</span>
            <span class="chip">{t.used_in.length} circuit{t.used_in.length === 1 ? '' : 's'}</span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section>
    <h2>Tube manuals</h2>
    <p class="sub">Receiving-tube manuals, catalogs, substitution guides, and the
      tube-amplifier design handbooks — the reference shelf for ratings, base
      diagrams, and circuit conventions. The tag on each entry records the basis for
      its copyright status.</p>
    <ul class="srclist">
      {manuals.map((s) => {
        const pd = pdBasis(s.pd_basis);
        return (
          <li>
            <div class="row1">
              <a href={s.url} rel="external nofollow">{s.title}</a>
              <span class={`chip ${pdClass[pd.token] ?? ''}`}>{pd.token}</span>
            </div>
            <div class="row2">{s.publisher} · {s.year} · {s.kind} · {s.host}</div>
            <p class="covers">{s.covers}</p>
            {pd.rest && <p class="pd">{pd.rest}</p>}
          </li>
        );
      })}
    </ul>
  </section>

  <section>
    <h2>Era components</h2>
    <p class="sub">The primary references behind the non-tube parts — output and
      power transformers, carbon-composition resistors, paper and electrolytic
      capacitors, rectifiers, speakers, and the early transistors of the pedal era.</p>
    <ul class="srclist">
      {era.map((s) => {
        const pd = pdBasis(s.pd_basis);
        return (
          <li>
            <div class="row1">
              <a href={s.url} rel="external nofollow">{s.title}</a>
              <span class={`chip ${pdClass[pd.token] ?? ''}`}>{pd.token}</span>
            </div>
            <div class="row2">{s.publisher} · {s.year} · {s.kind} · {s.host}</div>
            <p class="covers">{s.covers}</p>
            {pd.rest && <p class="pd">{pd.rest}</p>}
          </li>
        );
      })}
    </ul>
  </section>

  <p class="foot-note">Copyright tags are this project's good-faith reading of the
    evidence, not legal advice — <code>pd-outright</code> (published pre-1931),
    <code>non-renewal</code> (renewal window searched, none found),
    <code>pd-mark</code> (a Public Domain Mark applied by the archive),
    <code>renewal-dependent</code> (status turns on a renewal check we have not
    completed), <code>in-copyright</code> (linked for access only). When in doubt we
    link rather than rehost.</p>
</div>
</Base>

<style>
  .hero{padding:64px 0 20px}
  .eyebrow{font-family:var(--disp);text-transform:uppercase;letter-spacing:.26em;font-size:12.5px;color:var(--amber)}
  h1{font-size:clamp(30px,5vw,48px);line-height:1.1;margin:14px 0 16px}
  .lede{max-width:62ch;color:var(--muted);font-size:16.5px;margin:0 0 24px}
  .posture{max-width:70ch;background:var(--panel);border:1px solid var(--line);border-left:3px solid var(--amber);border-radius:6px;padding:16px 18px;color:var(--muted);font-size:14.5px}
  .posture strong{color:var(--ink)}
  section{margin-top:40px}
  h2{font-size:19px;letter-spacing:.14em;margin:24px 0 4px}
  .sub{color:var(--muted);font-size:14.5px;margin:0 0 20px;max-width:74ch}
  .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:14px}
  .card{background:var(--panel);border:1px solid var(--line);border-radius:8px;padding:16px 18px 14px;display:flex;flex-direction:column;gap:7px;color:inherit}
  .card:hover{border-color:var(--amber-dim);text-decoration:none}
  .card .cid{font-family:var(--disp);font-size:22px;letter-spacing:.04em;text-transform:uppercase}
  .card .ct{font-family:var(--disp);text-transform:uppercase;letter-spacing:.16em;font-size:10.5px;color:var(--amber)}
  .card.study .cid,.card.guide .cid{font-size:17px;line-height:1.25;text-transform:none;letter-spacing:.01em}
  .card .cdesc{color:var(--muted);font-size:13px;line-height:1.4}
  .card .cdesc.aka{font-family:var(--mono);font-size:11.5px;color:var(--faint);margin-top:-2px}
  .chips{display:flex;gap:8px;flex-wrap:wrap;margin-top:auto;padding-top:8px}
  .chip.warn{color:var(--oxblood);border-color:var(--oxblood)}
  .srclist{list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:2px}
  .srclist li{padding:15px 2px;border-bottom:1px solid var(--line-soft)}
  .srclist li:last-child{border-bottom:0}
  .row1{display:flex;align-items:baseline;gap:12px;flex-wrap:wrap}
  .row1 a{font-family:var(--disp);font-size:16.5px;letter-spacing:.02em}
  .row2{font-family:var(--mono);font-size:11.5px;color:var(--faint);margin-top:3px}
  .covers{color:var(--muted);font-size:14px;margin:8px 0 0;max-width:76ch}
  .pd{color:var(--faint);font-size:12.5px;margin:6px 0 0;max-width:76ch;font-style:italic}
  .foot-note{margin-top:36px;padding-top:16px;border-top:1px dashed var(--line);color:var(--faint);font-size:12.5px;max-width:80ch}
  .foot-note code{font-family:var(--mono);color:var(--muted);font-size:11.5px}
</style>
