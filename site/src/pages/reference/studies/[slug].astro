---
import Base from '../../../layouts/Base.astro';
import { loadStudies } from '../../../lib/corpus.js';

export async function getStaticPaths() {
  return loadStudies().map((s) => ({ params: { slug: s.slug }, props: { study: s } }));
}
const { study } = Astro.props;
---
<Base title={`${study.title} · Circuit Codex`}
      description={study.subtitle || `A Circuit Codex reference study: ${study.title}.`}>
<div class="wrap">
  <header class="shead">
    <a class="back" href="/reference/">← Reference</a>
    <div class="eyebrow">Study</div>
    <h1>{study.title}</h1>
    {study.subtitle && <p class="subtitle">{study.subtitle}</p>}
  </header>
  <article class="prose" set:html={study.html} />
</div>
</Base>

<style>
  .shead{padding:44px 0 8px}
  .back{font-family:var(--disp);text-transform:uppercase;letter-spacing:.14em;font-size:11.5px;color:var(--muted)}
  .eyebrow{font-family:var(--disp);text-transform:uppercase;letter-spacing:.26em;font-size:12px;color:var(--amber);margin-top:14px}
  h1{font-size:clamp(28px,4.5vw,42px);line-height:1.12;margin:8px 0 10px;max-width:24ch}
  .subtitle{color:var(--muted);font-size:16px;font-style:italic;margin:0}
  .prose{max-width:74ch;margin-top:20px}
  .prose :global(h2){font-size:17px;letter-spacing:.12em;margin:34px 0 8px}
  .prose :global(p){color:var(--muted);font-size:15.5px;line-height:1.7}
  .prose :global(li){color:var(--muted);font-size:15.5px;line-height:1.65}
  .prose :global(strong){color:var(--ink)}
  .prose :global(a){overflow-wrap:anywhere}
  .prose :global(code){font-family:var(--mono);font-size:12.5px;color:var(--ink);background:var(--well);padding:1px 5px;border-radius:3px}
  .prose :global(hr){border:0;border-top:1px dashed var(--line);margin:32px 0}
  .prose :global(em){color:var(--muted)}
  .prose :global(table){border-collapse:collapse;width:100%;font-size:13px;margin:14px 0;display:block;overflow-x:auto}
  .prose :global(th){font-family:var(--disp);text-transform:uppercase;letter-spacing:.1em;font-size:10.5px;color:var(--faint);text-align:left;padding:8px 12px;border-bottom:1px solid var(--line);background:var(--panel);white-space:nowrap}
  .prose :global(td){padding:7px 12px;border-bottom:1px solid var(--line-soft);font-family:var(--mono);font-size:12px;white-space:nowrap}
  .prose :global(blockquote){border-left:3px solid var(--line);margin:16px 0;padding-left:16px;color:var(--faint)}
</style>
