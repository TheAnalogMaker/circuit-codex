<script is:inline>
(function () {
  const fig = document.querySelector('.dis-fig');
  if (!fig) return;
  const svg = fig.querySelector('.dis-svg');
  const readout = fig.querySelector('.dis-readout');
  const def = readout.getAttribute('data-default');
  const steps = [...fig.querySelectorAll('.dstep')];

  const clear = () => {
    fig.classList.remove('has-active');
    svg.querySelectorAll('.part.lit').forEach((p) => p.classList.remove('lit'));
    steps.forEach((s) => s.classList.remove('is-active'));
  };
  const activate = (step) => {
    clear();
    fig.classList.add('has-active');
    step.classList.add('is-active');
    readout.textContent = step.getAttribute('data-readout');
    step.getAttribute('data-parts').split(/\s+/).forEach((tok) => {
      svg.querySelectorAll('.' + tok).forEach((el) => el.classList.add('lit'));
    });
  };
  const reset = () => {
    if (fig.contains(document.activeElement) && document.activeElement.classList.contains('dstep')) return;
    clear();
    readout.textContent = def;
  };
  steps.forEach((step) => {
    step.addEventListener('mouseenter', () => activate(step));
    step.addEventListener('focus', () => activate(step));
    step.addEventListener('click', () => activate(step));
    step.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); activate(step); }
    });
  });
  fig.addEventListener('mouseleave', reset);
  fig.addEventListener('focusout', () => setTimeout(reset, 0));
})();
</script>

