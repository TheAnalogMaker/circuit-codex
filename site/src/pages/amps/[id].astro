---
import Base from '../../layouts/Base.astro';
import { loadCorpus, GITHUB } from '../../lib/corpus.js';

export async function getStaticPaths() {
  return loadCorpus().map((amp) => ({ params: { id: amp.id }, props: { amp } }));
}
const { amp } = Astro.props;
const m = amp.meta;
const v = m.verification || {};
const vDate = v.date ? new Date(v.date).toISOString().slice(0, 10) : null;
const ghDir = `${GITHUB}/tree/main/amps/${amp.id}`;
---
<Base title={`${amp.id.toUpperCase()} — ${m.name_style} · Circuit Codex`}
      description={`${m.name_style} (${m.era.start}–${m.era.end}): structured metadata, simulation-checked netlist, and circuit walkthrough.`}>
<div class="wrap">
  <header class="amp-head">
    <h1>{amp.id.toUpperCase()}</h1>
    <span class="style">{m.name_style} · {m.era.start}–{m.era.end} · {m.wattage} W</span>
    {v.status === 'verified'
      ? <span class="chip ok">✓ verified {vDate}</span>
      : <span class="chip">draft</span>}
  </header>

  <div class="cols">
    <div class="main">
      <div class="viewer">
        <div class="viewer-head">Schematic</div>
        <div class="viewer-body">
          {amp.hasSchematic
            ? <p>Interactive schematic viewer coming online.</p>
            : <p>Redrawn KiCad schematic in progress. The simulation-checked
                <a href={`${ghDir}/netlist.cir`}> netlist</a> is already available —
                every voltage below derives from it.</p>}
        </div>
      </div>

      {amp.voltages && (
        <section>
          <h2>Operating point vs. published chart</h2>
          <p class="sub">Chart values read from the published drawing (never reproduced).
            {v.status === 'verified' && ` Simulation matches every node within tolerance — worst deviation ${v.max_deviation_pct}% (chart convention is ±20%).`}</p>
          <div class="tbl"><table>
            <thead><tr><th>Node</th><th>Chart</th><th>Tolerance</th><th>Note</th></tr></thead>
            <tbody>
              {Object.entries(amp.voltages.nodes).map(([node, e]) => (
                <tr>
                  <td>{node}</td>
                  <td>{e.chart === null || e.chart === undefined ? '—' : `${e.chart} V`}</td>
                  <td>{e.chart === null || e.chart === undefined ? '' : `±${e.tol_pct ?? 5}%`}</td>
                  <td style="font-family:var(--body);color:var(--faint)">{e.note || ''}</td>
                </tr>
              ))}
            </tbody>
          </table></div>
        </section>
      )}

      {amp.notesHtml && (
        <section>
          <h2>Circuit story</h2>
          <div class="notes" set:html={amp.notesHtml} />
        </section>
      )}
    </div>

    <aside class="meta">
      <dl>
        <dt>Circuit</dt><dd>{amp.id.toUpperCase()} ({m.name_style})</dd>
        <dt>Family</dt><dd>{m.family}</dd>
        <dt>Output</dt><dd>{m.wattage} W</dd>
        <dt>Tubes</dt><dd>{m.tubes.join(', ')}</dd>
        <dt>Rectifier</dt><dd>{m.topology.rectifier.type || m.topology.rectifier.kind}</dd>
        <dt>Bias</dt><dd>{m.topology.bias}</dd>
        <dt>Phase inv.</dt><dd>{m.topology.phase_inverter}</dd>
        <dt>Tone stack</dt><dd>{m.topology.tone_stack}</dd>
      </dl>
      <div class="files">
        <h3>Data</h3>
        <a href={`${ghDir}/meta.yaml`}>meta.yaml</a>
        {amp.hasNetlist && <a href={`${ghDir}/netlist.cir`}>netlist.cir</a>}
        {amp.voltages && <a href={`${ghDir}/voltages.yaml`}>voltages.yaml</a>}
        <a href={ghDir}>browse directory →</a>
      </div>
      {m.sources && (
        <div class="files">
          <h3>Sources</h3>
          <ul class="src">{m.sources.map((s) => <li>{s}</li>)}</ul>
        </div>
      )}
    </aside>
  </div>
</div>
</Base>

<style>
  .amp-head{display:flex;align-items:baseline;gap:16px;flex-wrap:wrap;padding:56px 0 8px}
  h1{font-size:38px;letter-spacing:.05em;margin:0}
  .style{color:var(--muted)}
  .cols{display:grid;grid-template-columns:1.7fr 1fr;gap:18px;align-items:start;margin-top:16px}
  @media(max-width:820px){.cols{grid-template-columns:1fr}}
  .viewer{background:var(--well);border:1px solid var(--line);border-radius:8px;margin-bottom:24px}
  .viewer-head{padding:10px 16px;border-bottom:1px solid var(--line-soft);font-family:var(--disp);text-transform:uppercase;letter-spacing:.12em;font-size:11.5px;color:var(--muted)}
  .viewer-body{padding:22px 18px;color:var(--muted);font-size:14.5px}
  .viewer-body p{margin:0}
  h2{font-size:17px;letter-spacing:.14em;margin:28px 0 4px}
  .sub{color:var(--muted);font-size:13.5px;margin:0 0 14px;max-width:70ch}
  .meta{background:var(--panel);border:1px solid var(--line);border-radius:8px;padding:18px;position:sticky;top:72px}
  .meta dl{margin:0;display:grid;grid-template-columns:auto 1fr;gap:7px 16px;font-size:14px}
  .meta dt{color:var(--faint);text-transform:uppercase;font-family:var(--disp);letter-spacing:.1em;font-size:11px;padding-top:2px}
  .meta dd{margin:0;font-family:var(--mono);font-size:12.5px}
  .files{margin-top:16px;border-top:1px dashed var(--line);padding-top:12px;display:flex;flex-direction:column;gap:6px}
  .files h3{font-size:12px;letter-spacing:.14em;margin:0 0 2px;color:var(--faint)}
  .files a{font-family:var(--mono);font-size:12.5px}
  .src{margin:0;padding-left:16px;font-size:12px;color:var(--faint)}
  .src li{margin-bottom:6px}
  .notes :global(h2){font-size:15px;letter-spacing:.12em;margin:22px 0 6px}
  .notes :global(p){color:var(--muted);font-size:14.5px;max-width:72ch}
  .notes :global(li){color:var(--muted);font-size:14.5px}
  .notes :global(table){font-size:13px;margin:10px 0}
  .notes :global(strong){color:var(--ink)}
</style>
