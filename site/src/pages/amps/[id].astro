---
import Base from '../../layouts/Base.astro';
import { loadCorpus, displayId, ampMetaDescription, layoutAlt, GITHUB } from '../../lib/corpus.js';

export async function getStaticPaths() {
  return loadCorpus().map((amp) => ({ params: { id: amp.id }, props: { amp } }));
}
const { amp } = Astro.props;
const m = amp.meta;
const v = m.verification || {};
const vDate = v.date ? new Date(v.date).toISOString().slice(0, 10) : null;
const ghDir = `${GITHUB}/tree/main/amps/${amp.id}`;
const metaDescription = ampMetaDescription(m);
const canonical = new URL(`amps/${amp.id}/`, Astro.site).href;
const jsonld = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: `${displayId(amp.id)} — ${m.name_style}`,
  name: `${displayId(amp.id)} — ${m.name_style}`,
  description: metaDescription,
  url: canonical,
  inLanguage: 'en',
  about: `${m.name_style} guitar amplifier circuit`,
  ...(vDate ? { datePublished: vDate } : {}),
  publisher: { '@type': 'Organization', name: 'Circuit Codex' },
};
---
<Base title={`${displayId(amp.id)} — ${m.name_style} · Circuit Codex`}
      description={metaDescription} ogType="article" jsonld={jsonld}>
<div class="wrap wrap-wide">
  <header class="amp-head">
    <h1>{displayId(amp.id)} <span class="style">{m.name_style} · {m.era.start}–{m.era.end} · {m.wattage} W</span></h1>
    {v.status === 'verified'
      ? <span class="chip ok">✓ verified {vDate}</span>
      : <span class="chip">draft</span>}
  </header>

  <div class="cols">
    <div class="main">
      <div class="viewer">
        <div class="viewer-head">Schematic — redrawn in KiCad · scroll to zoom, drag to pan</div>
        {amp.hasSchematic ? (
          <div class="viewer-canvas">
            <script type="module" src="/vendor/kicanvas.js" is:inline></script>
            <kicanvas-embed src={`/schematics/${amp.id}.kicad_sch`} controls="basic"
              aria-label={`Interactive schematic: ${m.name_style} ${displayId(amp.id)}, redrawn in KiCad`}></kicanvas-embed>
            <noscript><p class="viewer-fallback">Interactive schematic requires JavaScript.
              Download the redrawn KiCad schematic for {displayId(amp.id)}:
              <a href={`${ghDir}/schematic.kicad_sch`}>schematic.kicad_sch</a>.</p></noscript>
          </div>
        ) : (
          <div class="viewer-body">
            <p>Redrawn KiCad schematic in progress. The simulation-checked
              <a href={`${ghDir}/netlist.cir`}> netlist</a> is already available —
              every voltage below derives from it.</p>
          </div>
        )}
      </div>

      {amp.hasLayout && (
        <div class="viewer layout">
          <div class="viewer-head">Board layout — redrawn reference diagram · source noted on the drawing</div>
          <div class="layout-canvas">
            <img src={`/layouts/${amp.id}.svg`} loading="lazy" decoding="async"
              alt={layoutAlt(amp)} />
          </div>
          <p class="layout-note">
            This diagram documents connectivity and part arrangement — it is not a
            dimensioned 1:1 build template. Board and part positions are drawn at
            diagram scale, and lead dress, grounding paths, and physical spacing all
            matter in a high-voltage chassis. If you build from it, verify every
            connection against the schematic above and the operating-point table
            below as you go.
          </p>
        </div>
      )}

      {amp.voltages && (
        <section>
          <h2>Operating point vs. published chart</h2>
          <p class="sub">Chart values read from the published drawing (never reproduced).
            Tolerances are this project's verification targets — tighter on power rails
            than the ±20% measurement convention Fender printed on its charts.
            {v.status === 'verified' && ` Simulation matches every node within target — worst deviation ${v.max_deviation_pct}%.`}</p>
          <div class="tbl"><table>
            <thead><tr><th>Node</th><th>Chart</th><th>Tolerance</th><th>Note</th></tr></thead>
            <tbody>
              {Object.entries(amp.voltages.nodes).map(([node, e]) => (
                <tr>
                  <td>{node}</td>
                  <td>{e.chart === null || e.chart === undefined ? '—' : `${e.chart} V`}</td>
                  <td>{e.disputed ? <span class="chip">chart disputed</span> : (e.chart === null || e.chart === undefined ? '' : `±${e.tol_pct ?? 5}%`)}</td>
                  <td style="font-family:var(--body);color:var(--faint)">{e.dispute_note || e.note || ''}</td>
                </tr>
              ))}
            </tbody>
          </table></div>
          <p class="footnote">Tube-pin nodes are checked against the chart's own printed
            ±20% convention; power-rail nodes are held to tighter internal verification targets.</p>
        </section>
      )}

      {amp.bom && (
        <section>
          <h2>Parts list</h2>
          <p class="sub">Reference designators match the schematic above. {amp.bom.notes}</p>
          <div class="tbl"><table>
            <thead><tr><th>Ref</th><th>Part</th><th>Value / rating</th><th>Role</th></tr></thead>
            <tbody>
              {amp.bom.items.map((i) => (
                <tr>
                  <td style="color:var(--amber)">{i.ref}</td>
                  <td style="font-family:var(--body)">{i.part}</td>
                  <td>{i.value}</td>
                  <td style="font-family:var(--body);color:var(--faint)">{i.role}</td>
                </tr>
              ))}
            </tbody>
          </table></div>
        </section>
      )}

      {amp.notesHtml && (
        <section>
          <h2>Circuit story</h2>
          <div class="notes" set:html={amp.notesHtml} />
        </section>
      )}
    </div>

    <aside class="meta">
      <dl>
        <dt>Circuit</dt><dd>{displayId(amp.id)}</dd>
        <dt>Family</dt><dd>{m.family}</dd>
        <dt>Output</dt><dd>{m.wattage} W</dd>
        <dt>Tubes</dt><dd>{m.tubes.join(', ')}</dd>
        <dt>Rectifier</dt><dd>{m.topology.rectifier.type || m.topology.rectifier.kind}</dd>
        <dt>Bias</dt><dd>{m.topology.bias}</dd>
        <dt>Phase inv.</dt><dd>{m.topology.phase_inverter}</dd>
        <dt>Tone stack</dt><dd>{m.topology.tone_stack}</dd>
      </dl>
      <div class="files">
        <h3>Data</h3>
        <a href={`${ghDir}/meta.yaml`}>meta.yaml</a>
        {amp.hasNetlist && <a href={`${ghDir}/netlist.cir`}>netlist.cir</a>}
        {amp.voltages && <a href={`${ghDir}/voltages.yaml`}>voltages.yaml</a>}
        <a href={ghDir}>browse directory →</a>
      </div>
    </aside>
  </div>

  {m.sources && (
    <section class="sources">
      <h2>Sources</h2>
      <ul class="src">{m.sources.map((s) => (
        <li>{typeof s === 'string' ? s : (<>
          {s.desc}{s.url && <> — <a href={s.url} rel="external nofollow">{new URL(s.url).hostname}</a></>}
        </>)}</li>
      ))}</ul>
    </section>
  )}
</div>
</Base>

<style>
  .amp-head{display:flex;align-items:baseline;gap:16px;flex-wrap:wrap;padding:56px 0 8px}
  h1{font-size:38px;letter-spacing:.05em;margin:0}
  /* The subtitle now lives inside the h1 (one heading for SEO/a11y) but keeps its
     original look: body font, sentence case, muted, lighter than the display title. */
  h1 .style{font-family:var(--body);text-transform:none;font-weight:400;letter-spacing:normal;font-size:16px;color:var(--muted);white-space:normal}
  .wrap-wide{max-width:1140px}
  .cols{display:grid;grid-template-columns:1fr minmax(280px,340px);gap:24px;align-items:start;margin-top:16px}
  @media(max-width:820px){.cols{grid-template-columns:1fr}}
  .viewer{background:var(--well);border:1px solid var(--line);border-radius:8px;margin-bottom:24px}
  .viewer-head{padding:10px 16px;border-bottom:1px solid var(--line-soft);font-family:var(--disp);text-transform:uppercase;letter-spacing:.12em;font-size:11.5px;color:var(--muted)}
  .viewer-body{padding:22px 18px;color:var(--muted);font-size:14.5px}
  .viewer-body p{margin:0}
  .viewer-canvas{height:580px}
  .viewer-canvas kicanvas-embed{display:block;width:100%;height:100%}
  .layout-canvas{padding:10px}
  .layout-note{color:var(--muted);font-size:12.5px;line-height:1.55;margin:0;padding:10px 16px 14px;border-top:1px solid var(--line-soft);max-width:90ch}
  .layout-canvas img{display:block;width:100%;height:auto;border-radius:4px}
  h2{font-size:17px;letter-spacing:.14em;margin:28px 0 4px}
  .sub{color:var(--muted);font-size:13.5px;margin:0 0 14px;max-width:70ch}
  .footnote{color:var(--faint);font-size:12px;margin:10px 0 0;max-width:70ch}
  .viewer-fallback{padding:22px 18px;color:var(--muted);font-size:14.5px;margin:0}
  .meta{background:var(--panel);border:1px solid var(--line);border-radius:8px;padding:18px;position:sticky;top:72px}
  .meta dl{margin:0;display:grid;grid-template-columns:max-content 1fr;gap:9px 14px;font-size:14px}
  .meta dt{color:var(--faint);text-transform:uppercase;font-family:var(--disp);letter-spacing:.1em;font-size:11px;padding-top:2px}
  .meta dd{margin:0;font-family:var(--mono);font-size:12.5px;overflow-wrap:anywhere;line-height:1.5}
  .files{margin-top:16px;border-top:1px dashed var(--line);padding-top:12px;display:flex;flex-direction:column;gap:6px}
  .files h3{font-size:12px;letter-spacing:.14em;margin:0 0 2px;color:var(--faint)}
  .files a{font-family:var(--mono);font-size:12.5px}
  .sources{max-width:76ch}
  .src{margin:0;padding-left:16px;font-size:13px;color:var(--faint)}
  .src li{margin-bottom:6px}
  .notes :global(h2){font-size:15px;letter-spacing:.12em;margin:22px 0 6px}
  .notes :global(p){color:var(--muted);font-size:14.5px;max-width:72ch}
  .notes :global(li){color:var(--muted);font-size:14.5px}
  .notes :global(table){font-size:13px;margin:10px 0}
  .notes :global(strong){color:var(--ink)}
</style>
