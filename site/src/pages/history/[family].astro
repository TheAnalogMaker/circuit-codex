---
import Base from '../../layouts/Base.astro';
import { loadHistory, displayId, GITHUB } from '../../lib/corpus.js';

export async function getStaticPaths() {
  return loadHistory().map((fam) => ({ params: { family: fam.slug }, props: { fam } }));
}
const { fam } = Astro.props;
const models = fam.models;

// --- era timeline geometry ------------------------------------------------
// A horizontal Gantt-style era timeline: one row per model, ordered oldest-first
// (top to bottom), each a bar spanning years.start–years.end on a shared year axis.
// Documented models are solid amber bars linking their circuit page; history-tier
// models are outline bars. A faint left spine draws the succession — the line from one
// revision to the next — since the rows are already in chronological order.
const yrs = models.flatMap((m) => [m.years?.start, m.years?.end]).filter((y) => y != null);
const YMIN = Math.min(...yrs) - 1, YMAX = Math.max(...yrs) + 1;
const W = 1000, PAD_L = 168, PAD_R = 96, PAD_T = 30;
const X0 = PAD_L, X1 = W - PAD_R, PLOTW = X1 - X0;
const ROWH = 34, BARH = 16;
const xScale = (yr) => X0 + ((yr - YMIN) / (YMAX - YMIN)) * PLOTW;
const rows = models.map((m, i) => {
  const s = m.years.start, e = m.years.end;
  const x1 = xScale(s), x2 = Math.max(xScale(e), x1 + 4);
  const cy = PAD_T + i * ROWH + ROWH / 2;
  return { m, i, x1, x2, cy, start: s, end: e };
});
const AXIS_Y = PAD_T + models.length * ROWH + 6;
const H = AXIS_Y + 34;
const ticks = [];
for (let y = Math.ceil(YMIN / 5) * 5; y <= YMAX; y += 5) ticks.push(y);

// SEO
const nDoc = fam.documentedCount, nHist = models.length - nDoc;
const title = `${fam.title} — history & era timeline · Circuit Codex`;
const description =
  `The ${fam.title.replace(/^The /, '')} model by model, ${fam.eraStart}–${fam.eraEnd}: ` +
  `every revision dated, its tube complement and defining change sourced — ${nDoc} with a ` +
  `documented circuit, ${nHist} history-tier. ${fam.maker_style} guitar amplifier lineage.`;
const canonical = new URL(`history/${fam.slug}/`, Astro.site).href;
const jsonld = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: `${fam.title}: the model line and era timeline`,
  name: title,
  description,
  url: canonical,
  inLanguage: 'en',
  about: `${fam.maker_style} guitar amplifier line history`,
  publisher: { '@type': 'Organization', name: 'Circuit Codex' },
};
---
<Base title={title} description={description} ogType="article" jsonld={jsonld}>
<div class="wrap wrap-wide">
  <header class="page-head">
    <div class="eyebrow"><a href="/history/">History</a> · {fam.maker_style}</div>
    <h1>{fam.title}</h1>
    <p class="lede">{fam.summary}</p>
    <div class="tallies">
      <span class="chip">{fam.eraStart}–{fam.eraEnd}</span>
      <span class="chip">{models.length} model{models.length === 1 ? '' : 's'}</span>
      <span class="chip v">{nDoc} documented</span>
      {nHist > 0 && <span class="chip">{nHist} history-tier</span>}
    </div>
  </header>

  <figure class="fig">
    <figcaption class="fig-cap">Era timeline — each bar spans a model's production years;
      the chain from top to bottom is the line's succession.</figcaption>
    <div class="scroll">
      <svg class="tl" viewBox={`0 0 ${W} ${H}`} role="img"
           aria-label={`Era timeline of the ${fam.title}: ${models.length} models from ${fam.eraStart} to ${fam.eraEnd}, oldest at top, documented circuits highlighted.`}>
        <!-- year gridlines + axis -->
        <g class="grid">
          {ticks.map((yr) => (
            <g>
              <line x1={xScale(yr)} y1={PAD_T - 8} x2={xScale(yr)} y2={AXIS_Y} />
              <text class="yr" x={xScale(yr)} y={AXIS_Y + 18}>{yr}</text>
            </g>
          ))}
          <line class="axis" x1={X0} y1={AXIS_Y} x2={X1} y2={AXIS_Y} />
        </g>

        <!-- succession spine: connects each model's start to the next, oldest→newest -->
        {rows.slice(0, -1).map((r, i) => {
          const n = rows[i + 1];
          return <path class="spine" d={`M ${r.x1.toFixed(1)} ${r.cy} L ${r.x1.toFixed(1)} ${(n.cy - ROWH / 2).toFixed(1)} L ${n.x1.toFixed(1)} ${n.cy}`} fill="none" />;
        })}

        <!-- model bars -->
        {rows.map((r) => {
          const doc = r.m.documented;
          const href = doc ? `/amps/${r.m.ampId}/` : `/history/${fam.slug}/#m-${r.i}`;
          const w = (r.x2 - r.x1).toFixed(1);
          return (
            <a class={`row ${doc ? 'doc' : 'hist'}`} href={href}>
              <text class="desig" x={X0 - 12} y={r.cy} text-anchor="end" dominant-baseline="middle">{r.m.shortDesig}</text>
              <rect class="bar" x={r.x1.toFixed(1)} y={(r.cy - BARH / 2).toFixed(1)} width={w} height={BARH} rx="4" />
              <circle class="knot" cx={r.x1.toFixed(1)} cy={r.cy} r="3" />
              <text class="wtt" x={(r.x2 + 8).toFixed(1)} y={r.cy} dominant-baseline="middle">
                {r.m.wattage != null ? `${r.m.wattage} W` : '—'}{doc && <tspan class="tick"> ✓</tspan>}
              </text>
            </a>
          );
        })}
      </svg>
    </div>
  </figure>

  <div class="legend">
    <span class="lg"><span class="sw doc"></span>Documented circuit — links to its page</span>
    <span class="lg"><span class="sw hist"></span>History-tier — placed &amp; sourced, circuit not yet drawn</span>
    <span class="lg"><span class="sw-line"></span>Succession within the line</span>
  </div>

  <section>
    <h2>The models</h2>
    <div class="tbl"><table>
      <thead><tr><th>Designation</th><th>Years</th><th>Watts</th><th>Output stage</th><th>Key change</th><th>Circuit</th></tr></thead>
      <tbody>
        {models.map((m, i) => (
          <tr id={`m-${i}`}>
            <td class="d">{m.designation}</td>
            <td>{m.years.start}–{m.years.end}</td>
            <td>{m.wattage != null ? `${m.wattage} W` : '—'}</td>
            <td style="font-family:var(--body)">{m.output || '—'}</td>
            <td class="kc" style="font-family:var(--body)">{String(m.key_change).trim()}</td>
            <td>
              {m.documented
                ? <a class="badge ok" href={`/amps/${m.ampId}/`}>{displayId(m.ampId)} circuit ↗</a>
                : <a class="badge draft" href="/about/#contribute" title="Circuit not yet documented — how to contribute">history entry</a>}
            </td>
          </tr>
        ))}
      </tbody>
    </table></div>
    <p class="footnote">A <span class="badge ok inline">circuit ↗</span> badge links a fully
      documented circuit — redrawn schematic, verified operating point, parts list. A
      <span class="badge draft inline">history entry</span> is placed and sourced here but its
      circuit isn't drawn yet; <a href="/about/#contribute">contributions are welcome</a>.</p>
  </section>

  {fam.notes && (
    <section class="story">
      <h2>Dating &amp; notes</h2>
      {fam.notes.split(/\n\s*\n/).map((p) => <p>{p.replace(/\s+/g, ' ').trim()}</p>)}
    </section>
  )}

  <section class="src">
    <h2>Sources</h2>
    <p class="footnote">Every model above carries its own citations in the corpus data file.
      Browse the full source list for this line:
      <a href={`${GITHUB}/blob/main/history/families/${fam.slug}.yaml`}>history/families/{fam.slug}.yaml</a>.</p>
  </section>

  <p class="backlinks">
    <a href="/history/">← All family lines</a> · <a href="/lineage/">See the full lineage tree ↗</a>
  </p>
</div>
</Base>

<style>
  .wrap-wide{max-width:1140px}
  .page-head{padding:56px 0 8px}
  .eyebrow{font-family:var(--disp);text-transform:uppercase;letter-spacing:.2em;font-size:12.5px;color:var(--amber)}
  .eyebrow a{color:var(--amber)}
  h1{font-size:clamp(28px,5vw,46px);line-height:1.05;margin:10px 0 14px;letter-spacing:.05em}
  .lede{max-width:76ch;color:var(--muted);font-size:16px;line-height:1.6}
  .tallies{display:flex;gap:8px;flex-wrap:wrap;margin-top:14px}

  .fig{margin:28px 0 0}
  .fig-cap{color:var(--faint);font-size:12.5px;margin:0 2px 8px}
  .scroll{overflow-x:auto;border:1px solid var(--line);border-radius:10px;background:var(--well);padding:10px 8px 4px}
  .tl{display:block;width:100%;min-width:720px;height:auto}

  .tl .grid line{stroke:var(--line-soft);stroke-width:1}
  .tl .grid line.axis{stroke:var(--line);stroke-width:1.5}
  .tl .yr{fill:var(--faint);font-family:var(--mono);font-size:11px;text-anchor:middle}
  .tl .spine{stroke:var(--line);stroke-width:1.4;stroke-dasharray:2 3;opacity:.7}

  .tl .row{cursor:pointer}
  .tl .desig{fill:var(--ink);font-family:var(--disp);text-transform:uppercase;letter-spacing:.03em;font-size:13px;font-weight:600}
  .tl .wtt{fill:var(--faint);font-family:var(--mono);font-size:10.5px}
  .tl .wtt .tick{fill:var(--ok)}
  .tl .knot{fill:var(--muted)}

  .tl .doc .bar{fill:var(--amber-dim);stroke:var(--amber);stroke-width:1.4}
  .tl .doc .knot{fill:var(--amber)}
  .tl .doc .desig{fill:var(--amber)}
  .tl .hist .bar{fill:none;stroke:var(--faint);stroke-width:1.3;stroke-dasharray:4 3}
  .tl .row:hover .bar{stroke:var(--amber);stroke-width:1.8}
  .tl .row:hover .desig{fill:var(--amber)}

  .legend{display:flex;gap:20px;flex-wrap:wrap;margin:14px 2px 0;color:var(--faint);font-size:12px}
  .legend .lg{display:inline-flex;align-items:center;gap:7px}
  .legend .sw{width:22px;height:12px;border-radius:3px;display:inline-block}
  .legend .sw.doc{background:var(--amber-dim);border:1.4px solid var(--amber)}
  .legend .sw.hist{background:transparent;border:1.3px dashed var(--faint)}
  .legend .sw-line{width:22px;height:0;border-top:1.4px dashed var(--line);display:inline-block}

  section{margin:40px 0}
  h2{font-size:18px;letter-spacing:.14em;margin:0 0 12px}
  .d{color:var(--amber);white-space:nowrap}
  .kc{color:var(--muted);font-size:13px;line-height:1.5;min-width:320px}
  .badge{font-family:var(--disp);text-transform:uppercase;letter-spacing:.08em;font-size:10px;border:1px solid var(--line);border-radius:99px;padding:3px 9px;white-space:nowrap;display:inline-block}
  .badge.ok{color:var(--ok);border-color:var(--ok)}
  .badge.draft{color:var(--muted);border-color:var(--line)}
  .badge.inline{padding:1px 7px;font-size:9px}
  .footnote{color:var(--faint);font-size:12.5px;line-height:1.6;margin:12px 0 0;max-width:82ch}
  .story p{color:var(--ink);font-size:14.5px;max-width:80ch;margin:0 0 12px}
  .backlinks{margin:40px 0 0;font-family:var(--disp);text-transform:uppercase;letter-spacing:.1em;font-size:12px}
  @media(max-width:640px){.kc{min-width:200px}}
</style>
