---
const { title, description, jsonld, ogType = 'website' } = Astro.props;
import { GITHUB } from '../lib/corpus.js';

// Absolute URLs for canonical + social cards (Astro.site = https://circuitcodex.com).
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('og.png', Astro.site).href;

// Structured data: use whatever the page passed; otherwise, guide/safety pages
// get a default TechArticle so the reference section is machine-readable.
const path = Astro.url.pathname;
const isGuide = path.startsWith('/reference/guides/') || path.startsWith('/reference/safety');
let ld = jsonld;
if (!ld && isGuide) {
  ld = {
    '@context': 'https://schema.org',
    '@type': 'TechArticle',
    headline: title,
    name: title,
    description,
    url: canonical,
    inLanguage: 'en',
    publisher: { '@type': 'Organization', name: 'Circuit Codex' },
  };
}
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical} />
<link rel="sitemap" href="/sitemap-index.xml" />
<meta property="og:site_name" content="Circuit Codex" />
<meta property="og:type" content={ogType} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="Circuit Codex — verified tube-amp circuit archive" />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
{ld && <script type="application/ld+json" set:html={JSON.stringify(ld)} />}
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><circle cx='50' cy='55' r='30' fill='none' stroke='%23e89b3f' stroke-width='8'/><rect x='44' y='10' width='12' height='28' rx='4' fill='%23e89b3f'/></svg>" />
<style is:global>
  :root{
    --ground:#171310;--panel:#211a14;--well:#120f0c;
    --ink:#eee2c8;--muted:#a3927b;--faint:#7a6a54;
    --amber:#e89b3f;--amber-dim:#b97c33;--oxblood:#9c4a38;
    --ok:#8fae7e;--line:#3a3025;--line-soft:#2c241c;
    --disp:"Avenir Next Condensed","Arial Narrow","Helvetica Neue",Arial,sans-serif;
    --body:"Avenir Next",Seravek,"Segoe UI",system-ui,sans-serif;
    --mono:"SF Mono",Menlo,Consolas,monospace;
  }
  *{box-sizing:border-box}
  body{background:var(--ground);color:var(--ink);font-family:var(--body);line-height:1.6;margin:0;min-height:100vh}
  .wrap{max-width:1020px;margin:0 auto;padding:0 24px}
  a{color:var(--amber);text-decoration:none}
  a:hover,a:focus-visible{text-decoration:underline}
  :focus-visible{outline:2px solid var(--amber);outline-offset:2px;border-radius:2px}
  nav{border-bottom:1px solid var(--line);position:sticky;top:0;background:rgba(23,19,16,.94);backdrop-filter:blur(6px);z-index:9}
  .nav-in{display:flex;align-items:baseline;gap:28px;padding:14px 0;flex-wrap:wrap}
  .brand{font-family:var(--disp);text-transform:uppercase;letter-spacing:.22em;font-size:15px;color:var(--ink)}
  .brand b{color:var(--amber);font-weight:600}
  .nav-links{display:flex;gap:20px;margin-left:auto;font-family:var(--disp);text-transform:uppercase;letter-spacing:.14em;font-size:12.5px}
  .nav-links a{color:var(--muted)}
  h1,h2,h3{font-family:var(--disp);text-transform:uppercase;font-weight:600;letter-spacing:.06em;text-wrap:balance}
  .chip{font-family:var(--disp);text-transform:uppercase;letter-spacing:.1em;font-size:10.5px;border:1px solid var(--line);border-radius:99px;padding:2px 9px;color:var(--muted);white-space:nowrap}
  .chip.v{color:var(--amber);border-color:var(--amber-dim)}
  .chip.ok{color:var(--ok);border-color:var(--ok)}
  footer{margin-top:72px;border-top:1px solid var(--line);padding:28px 0 48px;color:var(--faint);font-size:13px}
  footer .row{display:flex;gap:24px;flex-wrap:wrap}
  footer a{color:var(--muted)}
  table{border-collapse:collapse;width:100%;font-size:13.5px}
  th{font-family:var(--disp);text-transform:uppercase;letter-spacing:.12em;font-size:11px;color:var(--faint);text-align:left;padding:10px 14px;border-bottom:1px solid var(--line);background:var(--panel)}
  td{padding:9px 14px;border-bottom:1px solid var(--line-soft);font-family:var(--mono);font-size:12.5px}
  tr:last-child td{border-bottom:0}
  .tbl{overflow-x:auto;border:1px solid var(--line);border-radius:8px}
</style>
</head>
<body>
<nav><div class="wrap nav-in">
  <a href="/" style="text-decoration:none"><span class="brand">The Analog Maker <b>/ Circuit Codex</b></span></a>
  <span class="nav-links">
    <a href="/#circuits">Circuits</a>
    <a href="/reference/">Reference</a>
    <a href="/about/">About</a>
    <a href={GITHUB}>GitHub</a>
    <a href="https://www.youtube.com/@theanalogmaker">YouTube</a>
  </span>
</div></nav>
<slot />
<footer><div class="wrap">
  <div class="row">
    <span>© 2026 The Analog Maker</span>
    <a href="/about/">About &amp; start here</a>
    <a href={GITHUB}>Corpus repo</a>
    <a href="/about/#contribute">Contribute</a>
    <a href={`${GITHUB}/blob/main/models/METHODOLOGY.md`}>Model methodology</a>
  </div>
  <p style="max-width:78ch">Every schematic here is independently redrawn from the underlying circuit —
    values, topology, published voltage charts — never scanned or traced from original factory drawings.
    Maker names identify circuits descriptively; this project is not affiliated with or endorsed by any
    amplifier manufacturer. Circuit data CC-BY-SA · code MIT · tube models CC0.</p>
  <p style="color:var(--oxblood)">⚡ Tube amplifiers carry lethal voltages, and filter capacitors hold
    charge long after power-off. Study freely; open a chassis only with <a href="/reference/safety/">high-voltage safety training</a>.</p>
</div></footer>
</body>
</html>
