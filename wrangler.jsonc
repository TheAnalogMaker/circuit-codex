{
  // Circuit Codex — static site deployment (Cloudflare Workers static assets)
  // The site is generated by Astro from the corpus data in amps/ and models/:
  // wrangler's custom build runs it automatically on `wrangler deploy`
  // (which is also what Workers Builds runs on every push to main).
  // Local: cd site && npm run dev   ·   Deploy: npx wrangler deploy
  "name": "circuit-codex",
  "compatibility_date": "2026-07-18",
  "build": {
    "command": "cd site && npm ci && npm run build",
    "watch_dir": "site/src"
  },
  "assets": {
    "directory": "./site/dist"
  }
}
